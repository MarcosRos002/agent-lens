{
  "title": "agent-lens — agent observability",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["agent-lens", "llm", "observability"],
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Step latency P95 (ms) by kind",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_lens_step_latency_ms_bucket[5m])) by (le, kind))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cost (USD) by model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(agent_lens_cost_usd_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tokens by model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(agent_lens_tokens_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error rate by type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(agent_lens_errors_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ]
}
